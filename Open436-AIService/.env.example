# 数据库（复用现有PostgreSQL实例，使用独立数据库名）
DATABASE_URL=postgresql://open436:open436@localhost:55432/ai_db

# Redis（使用DB 2，避免与Sa-Token默认DB 0冲突）
REDIS_URL=redis://localhost:6379/2

# Milvus向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530

# LLM
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 联网搜索（Tavily）
TAVILY_API_KEY=tvly-xxxxx

# 内部服务地址（本地开发用 localhost，Docker环境用容器名）
CONTENT_SERVICE_URL=http://localhost:8003
SECTION_SERVICE_URL=http://localhost:8005
USER_SERVICE_URL=http://localhost:8002
HOJ_API_URL=http://localhost:6688

# HOJ管理员账号（用于HOJ API鉴权）
HOJ_ADMIN_USER=admin
HOJ_ADMIN_PASS=admin123

# 内部API密钥（必须与现有Python服务的 INTERNAL_API_KEY 一致）
INTERNAL_API_KEY=open436-internal-secret

# Consul服务注册（可选，本地开发可不注册）
CONSUL_URL=http://localhost:8500
CONSUL_SERVICE_NAME=ai-service
SERVICE_PORT=8008

# 应用配置
APP_DEBUG=true
APP_LOG_LEVEL=info
